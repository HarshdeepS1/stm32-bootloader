/* USER CODE BEGIN 4 */

void jumpToApp(void) {
	uint32_t appAddress = 0x08008000;
	uint32_t* vectorTable = (uint32_t*)appAddress;
	uint32_t stackPointer = vectorTable[0];
	uint32_t resetHandler = vectorTable[1];

	HAL_UART_Transmit(&huart2, (uint8_t*)"Stack and reset read\r\n", 22, 100);

	__disable_irq();

	__set_MSP(stackPointer);


	void (*appStart)(void) = (void (*)(void)) resetHandler;

	// OK so issue was that when the bootloader hands control to app it didn't
	// enable interrupts so then HAL_GPIO_TogglePin doesn't work
	__enable_irq();

	appStart();

}


uint8_t parsePacket(XmodemPacket* curr_packet, uint8_t expectedBlock) {

	if (HAL_UART_Receive(&huart2, (uint8_t*) curr_packet, sizeof(XmodemPacket), 1000) != HAL_OK) return XMODEM_NAK;

	if (curr_packet->soh == XMODEM_EOT) return XMODEM_EOT;

	uint8_t my_checksum = 0;

	for (uint8_t i=0; i<XMODEM_DATA_SIZE; i++) {
		my_checksum += curr_packet->data[i];
	}

	if ((curr_packet->soh != XMODEM_SOH) || (curr_packet->checksum != my_checksum)
			|| (curr_packet->blockNum != ~(curr_packet->inverseBlockNum)) || (curr_packet->blockNum != expectedBlock)) {
		return XMODEM_NAK;
	}
	else return XMODEM_ACK;
}

